<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- User-facing settings may be restored. Volatile/sensitive runtime state must not. -->
        <exclude domain="sharedpref" path="DownloadPrefs.xml" />
        <exclude domain="sharedpref" path="AdBlockerPrefs.xml" />
        <exclude domain="sharedpref" path="ValidLinkCheckerPrefs.xml" />
        <exclude domain="file" path="app_cfg.dat" />
        <exclude domain="file" path="ad_hosts.txt" />
        <exclude domain="file" path="valid_links.txt" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="DownloadPrefs.xml" />
        <exclude domain="sharedpref" path="AdBlockerPrefs.xml" />
        <exclude domain="sharedpref" path="ValidLinkCheckerPrefs.xml" />
        <exclude domain="file" path="app_cfg.dat" />
        <exclude domain="file" path="ad_hosts.txt" />
        <exclude domain="file" path="valid_links.txt" />
    </device-transfer>
</data-extraction-rules>
